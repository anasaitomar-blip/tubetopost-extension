{
  "manifest_version": 3,
  "name": "TubeToPost - YouTube to LinkedIn AI Post Creator",
  "short_name": "TubeToPost",
  "version": "1.0.0",
  "description": "Convertissez une vidéo YouTube en post LinkedIn professionnel avec l'IA. Résumé IA, transcription vidéo en texte, créateur de contenu en un clic.",
  "author": "TubeToPost",
  "homepage_url": "https://tubetopost.com",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TubeToPost - Créer un post LinkedIn depuis YouTube",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:1234/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://tubetopost-backend.onrender.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
